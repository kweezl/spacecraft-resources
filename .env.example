# SpaceCraft resources tool (sc) configuration.
# Copy to .env (gitignored) and uncomment/edit the lines you need.
# Precedence: CLI flag > env var > built-in default (shown below).

# --- Shared ---
# SC_DATA=unpacked/data.cdb
# SC_ASSETS=unpacked

# --- extract ---
# Path to the .pak archive (no default; required as an argument or here).
# SC_EXTRACT_PAK=path/to/archive.pak
# SC_EXTRACT_OUT=unpacked

# --- parse-items ---
# SC_PARSE_ITEMS_OUT=generated/items.json

# --- parse-craft ---
# SC_PARSE_CRAFT_OUT=generated/craft.json

# --- parse-workshops ---
# SC_PARSE_WORKSHOPS_OUT=generated/workshops.json

# --- parse-contracts ---
# SC_PARSE_CONTRACTS_OUT=generated/contracts.json

# --- parse-item-categories ---
# SC_PARSE_ITEM_CATEGORIES_OUT=generated/item_categories.json

# --- parse-space-objects ---
# SC_PARSE_SPACE_OBJECTS_OUT=generated/space_objects.json

# --- parse-factions ---
# SC_PARSE_FACTIONS_OUT=generated/factions.json

# --- parse-translations ---
# SC_PARSE_TRANSLATIONS_OUT=generated/i18n
# SC_PARSE_TRANSLATIONS_LANG_DIR=unpacked/extra/lang

# --- generate-icons ---
# SC_GENERATE_ICONS_OUT=generated/icons
# SC_GENERATE_ICONS_MANIFEST=generated/icons_manifest.json
# Alias map written in dedup mode (default on); item id -> canonical icon file.
# SC_GENERATE_ICONS_ALIASES=generated/aliases.json
# CDB sheet to generate icons from (default item). Empty = all sheets + filter.
# SC_GENERATE_ICONS_SHEET=item
# Icon output format: webp (default) or png.
# SC_GENERATE_ICONS_FORMAT=webp
# Extra icon sets (own dirs + alias maps; ids not globally unique).
# SC_GENERATE_ICONS_CATEGORIES_OUT=generated/icons-categories
# SC_GENERATE_ICONS_CATEGORIES_MANIFEST=generated/icons-categories_manifest.json
# SC_GENERATE_ICONS_CATEGORIES_ALIASES=generated/aliases-categories.json
# SC_GENERATE_ICONS_FACTIONS_OUT=generated/icons-factions
# SC_GENERATE_ICONS_FACTIONS_MANIFEST=generated/icons-factions_manifest.json
# SC_GENERATE_ICONS_FACTIONS_ALIASES=generated/aliases-factions.json

# --- deduplicate-icons ---
# SC_DEDUPLICATE_ICONS_MANIFEST=generated/icons_manifest.json

# --- serve (items inspector; dev-only, serves src/public + generated/) ---
# SC_SERVE_HOST=127.0.0.1
# SC_SERVE_PORT=8000
